                                class="fas fa-chevron-right"></i></button>
                    </div>
                </div>

                <!-- 2. Main Layout (Sequential Full Width) -->
                <div class="tracker-layout">

                    <!-- A. CONSISTENCY FLOW (Full Width) -->
                    <div class="tracker-chart-full">
