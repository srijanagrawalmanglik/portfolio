                .card-title {
                    font-family: 'Outfit';
                    font-weight: 700;
                    font-size: 1.1rem;
                    margin-bottom: 1.2rem;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    color: var(--primary);
                    /* Gold */
                }
