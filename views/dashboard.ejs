                }

                .t-col-habit {
                    position: sticky;
                    left: 0;
                    background: #121218;
                    z-index: 21;
                    text-align: left;
                    padding: 0 1.8rem;
                    min-width: 280px;
                    /* Wider for labels */
                    border-right: 3px solid var(--primary);
                    /* Stronger accent vertical */
                    font-family: 'Outfit';
                    font-weight: 600;
                    font-size: 1rem;
                    color: #fff;
                    box-shadow: 10px 0 15px -10px rgba(0, 0, 0, 0.5);
                }

                .t-cell-check {
                    width: 100%;
                    height: 100%;
                    cursor: pointer;
                    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
