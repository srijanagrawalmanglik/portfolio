                    border-radius: 16px;
                    padding: 1.5rem;
                    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
                    min-height: 380px;
                }

                .tracker-matrix-wrapper {
                    display: flex;
                    flex-direction: column;
                    background: rgba(16, 16, 24, 0.6);
                    backdrop-filter: blur(12px);
                    border: 1px solid rgba(255, 255, 255, 0.05);
                    border-radius: 16px;
                    width: 100%;
                    min-height: 400px;
                    height: auto;
                    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
                    margin-bottom: 1.5rem;
                    overflow: visible;
                }

                .tracker-bottom-grid {
                    display: grid;
                    grid-template-columns: 1fr 1fr 1fr;
                    gap: 1.5rem;
                    margin-top: 1.5rem;
                }

                .tracker-header-controls {
                    padding: 1.2rem;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                    background: rgba(255, 255, 255, 0.02);
                }

                .tracker-grid-container {
                    width: 100%;
                    overflow: auto;
                    position: relative;
                    scroll-behavior: smooth;
                    max-height: 1000px;
                }

                .tracker-grid-container::-webkit-scrollbar {
                    width: 8px;
                    height: 8px;
                }

                .tracker-grid-container::-webkit-scrollbar-track {
                    background: rgba(0, 0, 0, 0.2);
                }

                .tracker-grid-container::-webkit-scrollbar-thumb {
                    background: rgba(255, 215, 0, 0.15);
                    border-radius: 10px;
                }

                .tracker-grid-container::-webkit-scrollbar-thumb:hover {
                    background: var(--primary);
                }

                .tracker-sidebar-compact {
                    display: grid;
                    grid-template-columns: 1fr 2fr;
                    gap: 1.5rem;
                }

                .tracker-analog-footer {
                    display: none;
                    /* Replaced by bottom-grid */
                }


                /* Grid Table */
                .t-table {
                    border-collapse: separate;
                    border-spacing: 0;
                    min-width: 100%;
                }

                .t-cell {
                    border-right: 1px solid rgba(255, 255, 255, 0.05);
                    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                    padding: 0;
                    text-align: center;
                    position: relative;
                    height: 54px;
                    /* Slightly taller for better touch targets */
                    transition: background 0.2s;
                }

                tr:hover .t-cell {
                    background: rgba(255, 255, 255, 0.01);
                }

                .t-head-date {
                    position: sticky;
                    top: 0;
                    background: #0d0d12;
                    z-index: 30;
                    /* Higher than sticky col */
                    font-weight: 700;
                    font-size: 0.7rem;
                    height: 60px;
                    color: rgba(255, 255, 255, 0.4);
                    border-bottom: 2px solid rgba(255, 215, 0, 0.1);
                    text-transform: uppercase;
