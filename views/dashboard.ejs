                                </div>
                                <div
                                    style="flex: 1; max-width: 120px; display: flex; flex-direction: column; align-items: center; gap: 0.8rem;">
                                    <div
                                        style="width: 100%; background: rgba(100,100,255,0.1); border-radius: 8px; height: 160px; position: relative; overflow: hidden; border: 1px solid rgba(41,121,255,0.1);">
                                        <div id="metricRecoveryBar"
                                            style="position: absolute; bottom: 0; width: 100%; background: linear-gradient(0deg, #0d47a1, #2979ff); height: 60%; box-shadow: 0 0 20px rgba(41,121,255,0.4); transition: height 1s cubic-bezier(0.4, 0, 0.2, 1);">
                                        </div>
                                    </div>
                                    <span
                                        style="font-size: 0.75rem; font-weight: 700; color: #2979ff; letter-spacing: 1px;">RECOVERY
                                        <span id="metricRecoveryVal">60%</span></span>
                                </div>
                            </div>
                        </div>
                    </div>


                    <!-- D. SECONDARY ROW -->
                    <div class="tracker-bottom-grid" style="margin-top: 0;">
                        <!-- Protocols -->
                        <div class="analog-card">
                            <div class="card-title">
                                <span>Daily Protocols</span>
                                <i class="fas fa-shield-alt"></i>
                            </div>
                            <div id="protocolList"></div>
                        </div>
                        <!-- Top Habits -->
                        <div class="analog-card" style="grid-column: span 2;">
                            <div class="card-title">Top Performing Habits</div>
                            <div id="topHabitsList" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem;">
                                <!-- Injected -->
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- 8. AUTOMATION BOT -->
        <section id="automation" class="tab-section">
            <div class="card"
                style="background: #0f0f13; border: 1px solid #333; font-family: 'Courier New', monospace;">
                <div
                    style="display: flex; justify-content: space-between; margin-bottom: 1rem; border-bottom: 1px solid #333; padding-bottom: 1rem;">
                    <span style="color: var(--success);">● BOT_V1.0 ONLINE</span>
                    <span style="color: var(--text-secondary);">ID: #8829-X</span>
                </div>

                <div id="botConsole"
                    style="height: 300px; overflow-y: auto; color: #ccc; font-size: 0.9rem; margin-bottom: 1rem; padding-right: 0.5rem;">
                    <div style="margin-bottom: 0.5rem;">[SYSTEM] Initializing Job Automation Protocol...</div>
                    <div style="margin-bottom: 0.5rem;">[SYSTEM] LinkedIn API: Disconnected</div>
                    <div style="margin-bottom: 0.5rem;">[SYSTEM] Waiting for command...</div>
                </div>

                <div style="display: flex; gap: 1rem;">
                    <button class="btn btn-ghost" onclick="botCmd('scan_jobs')">Scan Job Boards</button>
                    <button class="btn btn-ghost" onclick="botCmd('optimize_resume')">Optimize Resume</button>
                    <button class="btn btn-ghost" onclick="botCmd('auto_apply')">Auto-Apply (Sim)</button>
                    <button class="btn btn-danger" onclick="botCmd('clear')">Clear Log</button>
                </div>
        </section>

        <!-- 9. GOOGLE CALENDAR (NEW) -->
        <section id="calendar" class="tab-section">
            <div class="card" style="height: 80vh; display: flex; flex-direction: column;">
                <div class="card-header">
                    <span class="card-title">Schedule & Events</span>
                    <% if(!googleLinked) { %>
                        <a href="/auth/google" class="btn btn-primary" style="font-size: 0.8rem;">
                            <i class="fab fa-google"></i> Connect Google Calendar
                        </a>
                        <% } else { %>
                            <button class="btn btn-primary" onclick="showAddEventModal()">
                                <i class="fas fa-plus"></i> Add Event
                            </button>
                            <% } %>
                </div>

                <!-- Always show calendar container -->
                <div id="calendarView" style="flex: 1; color: white;"></div>
            </div>

            <!-- ADD EVENT MODAL (Simple overlay) -->
            <div id="eventModal"
                style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.8); z-index: 1000; align-items:center; justify-content:center;">
                <div class="card" style="width: 400px; max-width: 90%;">
                    <h3 style="margin-bottom: 1.5rem;">Add New Event</h3>
                    <form action="/api/calendar/add" method="POST">
                        <div class="input-group">
                            <label class="input-label">Event Title</label>
                            <input type="text" name="summary" required>
                        </div>
                        <div class="input-group">
                            <label class="input-label">Start</label>
                            <input type="datetime-local" name="startDateTime" required style="color-scheme: dark;">
                        </div>
                        <div class="input-group">
                            <label class="input-label">End</label>
                            <input type="datetime-local" name="endDateTime" required style="color-scheme: dark;">
                        </div>
                        <div style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 1rem;">
                            <button type="button" class="btn btn-ghost"
                                onclick="document.getElementById('eventModal').style.display='none'">Cancel</button>
                            <button class="btn btn-primary">Save Event</button>
                        </div>
                    </form>
                </div>
            </div>

        </section>

        <!-- 5. SETTINGS -->
        <section id="settings" class="tab-section">
            <div class="card" style="max-width: 500px; margin: 0 auto;">
                <h3 style="margin-bottom: 2rem; font-family: 'Outfit';">Security Settings</h3>
                <form action="/admin/settings/password" method="POST">
                    <div class="input-group">
                        <label class="input-label">New Admin Password</label>
                        <input type="password" name="newPassword" required placeholder="••••••••">
                    </div>
                    <div class="input-group" style="margin-bottom: 2rem;">
                        <label class="input-label">Confirm Password</label>
                        <input type="password" name="confirm" required placeholder="••••••••">
                    </div>
                    <button class="btn btn-primary" style="width: 100%;">Update Security Info</button>
                </form>
            </div>
        </section>

    </main>

    <script>
        function showAddEventModal() {
            document.getElementById('eventModal').style.display = 'flex';
        }

        // CALENDAR INIT
        document.addEventListener('DOMContentLoaded', function () {
            // 1. Check URL for Tab
            const urlParams = new URLSearchParams(window.location.search);
            const activeTab = urlParams.get('tab');
            if (activeTab) {
                switchTab(activeTab);
            }

            // 2. Init Calendar if visible or just prepared
            var calendarEl = document.getElementById('calendarView');
            if (calendarEl) {
                var calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'dayGridMonth',
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'dayGridMonth,timeGridWeek,timeGridDay'
                    },
                    height: '100%',
                    navLinks: true, // can click day/week names to navigate views
                    editable: true,
                    selectable: true,
                    selectMirror: true,
                    dayMaxEvents: true, // allow "more" link when too many events

                    // 24-Hour Settings
                    slotMinTime: '00:00:00',
                    slotMaxTime: '24:00:00',
                    scrollTime: '08:00:00', // Start scroll at 8am but allow scrolling up to 00:00
                    expandRows: true, // Stretch to fit height

                    // Open Modal on Date Click
                    select: function (arg) {
                        // Pre-fill dates if possible (requires input IDs)
                        // For now just open modal
                        showAddEventModal();
                        calendar.unselect();
                    },
                    events: function (info, successCallback, failureCallback) {
                        fetch(`/api/calendar/events?start=${info.startStr}&end=${info.endStr}`)
                            .then(res => res.json())
                            .then(data => {
                                if (data.needsAuth) {
                                    successCallback([]); // Return empty if not auth'd
                                } else if (data.events) {
                                    successCallback(data.events);
                                } else {
                                    successCallback([]);
                                }
                            })
                            .catch(err => {
                                console.error(err);
                                failureCallback(err);
                            });
                    },
                    themeSystem: 'standard'
                });
                // Hack to render properly when tab switches
                window.renderCalendar = function () {
                    setTimeout(() => calendar.render(), 100);
                };

                // If calendar tab was auto-selected, render it now
                if (activeTab === 'calendar') window.renderCalendar();
            }
        });

        // ATTENDANCE SYNC LOGIC
        async function syncAttendance() {
            const container = document.getElementById('attendanceContent');
            const unmarkedContainer = document.getElementById('unmarkedSection');
            const unmarkedList = document.getElementById('unmarkedList');

            try {
                const res = await fetch('/api/attendance');
                const data = await res.json();

                if (data.needsAuth) {
                    container.innerHTML = '<div style="text-align:center;"><a href="/auth/google" class="btn btn-primary">Connect Google Calendar First</a></div>';
                    return;
                }

                if (data.subjects && data.subjects.length > 0) {
                    let html = '';
                    // Stats Cards
                    html += '<div class="dashboard-grid" style="grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));">';
                    data.subjects.forEach(sub => {
                        const stat = data.stats[sub.id] || { attended: 0, total: 0, pct: 0 };
                        let color = stat.pct >= 75 ? 'var(--success)' : (stat.pct >= 60 ? 'var(--accent)' : 'var(--danger)');

                        html += `
                            <div class="card">
                                <div style="display:flex; justify-content:space-between; margin-bottom:0.5rem;">
                                    <strong>${sub.name}</strong>
                                    <span style="color:var(--text-secondary);">${sub.code}</span>
                                </div>
                                <div style="font-size: 2rem; color:${color}; font-weight:bold;">${stat.pct}%</div>
                                <div style="color:var(--text-secondary);">
                                    ${stat.attended} / ${stat.total} Attended
                                </div>
                                <form action="/api/attendance/delete" method="POST" onsubmit="return confirm('Delete?')" style="margin-top:1rem;">
                                    <input type="hidden" name="id" value="${sub.id}">
                                    <button class="btn btn-ghost" style="padding: 0.2rem 0.5rem; font-size: 0.8rem;">Delete</button>
                                </form>
                            </div>
                        `;
                    });
                    html += '</div>';
                    container.innerHTML = html;

                    // Unmarked List
                    if (data.unmarkedEvents && data.unmarkedEvents.length > 0) {
                        unmarkedContainer.style.display = 'block';
                        unmarkedList.innerHTML = data.unmarkedEvents.map(ev => `
                            <div style="display:flex; justify-content:space-between; align-items:center; background:rgba(255,255,255,0.03); padding:0.8rem; margin-bottom:0.5rem; border-radius:8px;">
                                <div>
                                    <div style="font-weight:bold; color:white;">${ev.summary}</div>
                                    <div style="font-size:0.8rem; color:var(--text-secondary);">${new Date(ev.start).toLocaleString()}</div>
                                </div>
                                <div style="display:flex; gap:0.5rem;">
                                    <button onclick="markEvent('${ev.eventId}', '${ev.subjectId}', 'present')" class="btn" style="background:rgba(0,255,0,0.1); color:var(--success);">Present</button>
                                    <button onclick="markEvent('${ev.eventId}', '${ev.subjectId}', 'absent')" class="btn" style="background:rgba(255,0,0,0.1); color:var(--danger);">Absent</button>
                                </div>
                            </div>
                        `).join('');
                    } else {
                        unmarkedContainer.style.display = 'none';
                    }

                } else {
                    container.innerHTML = '<div style="text-align:center; padding:2rem; opacity:0.6;">No subjects added. Click "+ Add Subject" to start tracking.</div>';
                }
            } catch (e) {
                console.error(e);
                container.innerHTML = '<div style="color:var(--danger);">Error syncing attendance.</div>';
            }
        }

        async function markEvent(eventId, subjectId, status) {
            await fetch('/api/attendance/mark-event', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ eventId, subjectId, status })
            });
            syncAttendance(); // Refresh
        }

        // TABS (Modified to trigger calendar render AND attendance sync)
        function switchTab(id, el) {
            document.querySelectorAll('.tab-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));

            document.getElementById(id).classList.add('active');
            if (el) el.classList.add('active');

            document.getElementById('pageTitle').innerText = id === 'bio' ? 'Content Management' : (id.charAt(0).toUpperCase() + id.slice(1));

            if (id === 'calendar' && window.renderCalendar) window.renderCalendar();
            if (id === 'attendance') syncAttendance();
        }

        // CHART
        const ctx = document.getElementById('mainChart');
        if (ctx) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'Visitors',
                        data: [150, 230, 180, 320, 290, 450, 500],
                        borderColor: '#536dfe',
                        backgroundColor: (ctx) => {
                            const bg = ctx.chart.ctx.createLinearGradient(0, 0, 0, 250);
                            bg.addColorStop(0, 'rgba(83, 109, 254, 0.4)');
                            bg.addColorStop(1, 'rgba(83, 109, 254, 0)');
                            return bg;
                        },
                        tension: 0.4,
                        fill: true,
                        pointBackgroundColor: '#050507',
                        pointBorderColor: '#536dfe',
                        pointBorderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { color: '#666' } },
                        y: { border: { display: false }, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#666' } }
                    }
                }
            });
        }

        // --- TRACKER V4: HYBRID ENGINE ---
        let trackerData = { template: [], logs: {}, goals: {}, protocols: {}, moods: {}, achievements: [] };
        let currentDate = new Date(); // Represents the layout month
        let charts = {}; // Store Chart instances

        function getDatestamp(d) {
            return d.toISOString().split('T')[0];
        }

        async function initTracker() {
            try {
                const res = await fetch('/api/tracker');
                trackerData = await res.json();

                // Init Defaults if missing
                if (!trackerData.goals) trackerData.goals = {};
                if (!trackerData.protocols) trackerData.protocols = {};
                if (!trackerData.moods) trackerData.moods = {};

                renderTracker(); // Render All Components
            } catch (e) {
                console.error("Tracker Init Error", e);
            }
        }

        function changeMonth(delta) {
            currentDate.setMonth(currentDate.getMonth() + delta);
            renderTracker();
        }

        function renderTracker() {
            const dateLabel = document.getElementById('trackerMonthLabel');
            if (dateLabel) dateLabel.innerText = currentDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

            renderGrid();
            renderAnalytics();
            renderAnalog();
        }

        // 1. RENDER GRID (99 Habits)
        function renderGrid() {
            const header = document.getElementById('gridHeader');
            const body = document.getElementById('gridBody');
            if (!header || !body) return;

            header.innerHTML = '';
            body.innerHTML = '';

            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            const todayStr = getDatestamp(new Date());

            // --- OPTIMIZATION: Pre-process logs for O(1) lookup ---
            const monthCache = {};
            for (let d = 1; d <= daysInMonth; d++) {
                const date = new Date(year, month, d);
                const dStr = getDatestamp(date);
                monthCache[dStr] = {};
                if (trackerData.logs[dStr] && trackerData.logs[dStr].tasks) {
                    trackerData.logs[dStr].tasks.forEach(t => {
                        if (t.status === 'executed') monthCache[dStr][t.name] = true;
                    });
                }
            }

            // --- HEADERS ---
            const trHead = document.createElement('tr');
            // Sticky Corner
            const thCorner = document.createElement('th');
            thCorner.className = 't-col-habit';
            thCorner.innerText = "HABIT";
            thCorner.style.zIndex = '30';
            trHead.appendChild(thCorner);

            for (let d = 1; d <= daysInMonth; d++) {
                const date = new Date(year, month, d);
                const dStr = getDatestamp(date);
                const th = document.createElement('th');
                th.className = 't-head-date';
                th.innerText = d;

                // Highlight Today
                if (dStr === todayStr) {
                    th.style.color = 'var(--accent)';
                    th.style.borderBottom = '2px solid var(--accent)';
                }
                trHead.appendChild(th);
            }
            header.appendChild(trHead);

            // --- ROWS ---
            if (trackerData.template.length === 0) {
                const tr = document.createElement('tr');
                tr.innerHTML = `<td colspan="${daysInMonth + 1}" style="padding:2rem; text-align:center; color:var(--text-secondary);">No habits defined. Click "Add Habit" to start.</td>`;
                body.appendChild(tr);
                return;
            }

            trackerData.template.forEach(habit => {
                const tr = document.createElement('tr');

                // Habit Name (Sticky Left)
                const tdName = document.createElement('td');
                tdName.className = 't-col-habit t-cell';
                tdName.style.display = 'flex';
                tdName.style.alignItems = 'center';
                tdName.style.justifyContent = 'space-between';
                tdName.innerHTML = `<span>${habit}</span> <i class="fas fa-trash" style="font-size:0.7rem; opacity:0.3; cursor:pointer;" onclick="deleteHabit('${habit}')"></i>`;
                tr.appendChild(tdName);

                // Checkboxes
                for (let d = 1; d <= daysInMonth; d++) {
                    const date = new Date(year, month, d);
                    const dStr = getDatestamp(date);
                    const td = document.createElement('td');
                    td.className = 't-cell';

                    // Check status (Optimized O(1))
                    let isChecked = false;
                    if (monthCache[dStr] && monthCache[dStr][habit]) {
                        isChecked = true;
                    }

                    // Clickable Cell
                    const cellDiv = document.createElement('div');
                    cellDiv.className = `t-cell-check ${isChecked ? 'checked' : ''}`;
                    cellDiv.style.height = '100%';
                    cellDiv.onclick = () => toggleGridCheck(dStr, habit);

                    // Future Lock
                    if (date > new Date()) {
                        cellDiv.style.opacity = '0.1';
                        cellDiv.style.pointerEvents = 'none';
                    }

                    td.appendChild(cellDiv);
                    tr.appendChild(td);
                }
                body.appendChild(tr);
            });

            // --- INLINE ADDITION ROW ---
            const trAdd = document.createElement('tr');
            const tdInput = document.createElement('td');
            tdInput.className = 't-col-habit t-cell';
            tdInput.style.padding = '0';
            tdInput.innerHTML = `
                <div style="display:flex; align-items:center; width:100%; height:100%; background:rgba(255,255,255,0.02); padding:0 1rem; border:1px solid rgba(83,109,254,0.1); border-radius:4px;">
                    <input type="text" id="inputInlineHabit" placeholder="+ Add New Habit..." 
                        style="background:transparent; border:none; color:#fff; width:100%; outline:none; font-size:0.85rem;"
                        onkeydown="if(event.key==='Enter') submitInlineHabit()">
                    <i class="fas fa-plus" style="color:var(--primary); cursor:pointer; font-size:0.8rem;" onclick="submitInlineHabit()"></i>
                </div>
            `;
            trAdd.appendChild(tdInput);

            // Empty cells for the rest of the row
            for (let d = 1; d <= daysInMonth; d++) {
                const td = document.createElement('td');
                td.className = 't-cell';
                td.style.background = 'rgba(255,255,255,0.01)';
                trAdd.appendChild(td);
            }
            body.appendChild(trAdd);
        }

        async function toggleGridCheck(dateStr, habitName) {
            // Auto-init log if needed
            if (!trackerData.logs[dateStr]) {
                trackerData.logs[dateStr] = { tasks: [], score: 0 };
            }
            let log = trackerData.logs[dateStr];
            let task = log.tasks.find(t => t.name === habitName);

            // If task doesn't exist in log, create it
            if (!task) {
                task = { name: habitName, status: 'to-do' };
                log.tasks.push(task);
            }

            // Toggle
            task.status = (task.status === 'executed') ? 'to-do' : 'executed';

            // Recalc Score
            const total = trackerData.template.length;
            const executed = log.tasks.filter(t => t.status === 'executed').length;
            log.score = total > 0 ? Math.round((executed / total) * 100) : 0;

            // Updated Optimistic Render
            // Re-render only this cell? Complex. Re-render Grid is safer.
            // But to avoid scroll jump, we could just update style. 
            // For MVP speed, re-render whole Grid is fine if performance holds.
            renderGrid();
            renderAnalytics();

            // Save
            await fetch('/api/tracker/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ date: dateStr, log })
            });
        }

        async function submitInlineHabit() {
            const input = document.getElementById('inputInlineHabit');
            const name = input.value.trim();
            if (name) {
                trackerData.template.push(name);
                input.value = '';
                renderTracker();
                await fetch('/api/tracker/template', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ template: trackerData.template })
                });
            }
        }

        async function deleteHabit(name) {
            if (!confirm(`Delete habit "${name}" from your template?`)) return;
            trackerData.template = trackerData.template.filter(t => t !== name);
            renderTracker();
            await fetch('/api/tracker/template', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ template: trackerData.template })
            });
        }

        // 2. RENDER ANALYTICS (Charts)
        function renderAnalytics() {
            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            const labels = [];
            const dataConsistency = [];
            let totalChecks = 0;
            let possibleChecks = 0;

            for (let d = 1; d <= daysInMonth; d++) {
                labels.push(d);
                const dStr = getDatestamp(new Date(year, month, d));
                const log = trackerData.logs[dStr];
                dataConsistency.push(log ? log.score : 0);

                if (new Date(year, month, d) <= new Date()) {
                    possibleChecks += trackerData.template.length;
                    if (log) {
                        log.tasks.forEach(t => { if (t.status === 'executed' && trackerData.template.includes(t.name)) totalChecks++; });
                    }
                }
            }

            // A) Consistency Chart (Line)
            const ctxCon = document.getElementById('chartConsistency');
            if (ctxCon) {
                if (charts.consistency) charts.consistency.destroy();
                charts.consistency = new Chart(ctxCon, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Execution Score',
                            data: dataConsistency,
                            borderColor: '#00e5ff',
                            backgroundColor: (ctx) => {
                                const bg = ctx.chart.ctx.createLinearGradient(0, 0, 0, 300);
                                bg.addColorStop(0, 'rgba(0, 229, 255, 0.4)');
                                bg.addColorStop(1, 'rgba(0, 229, 255, 0)');
                                return bg;
                            },
                            tension: 0.4,
                            fill: true,
                            pointRadius: 5,
                            pointBackgroundColor: '#121218',
                            pointBorderColor: '#00e5ff',
                            pointBorderWidth: 2,
                            pointHoverRadius: 8,
                            pointHoverBackgroundColor: '#00e5ff',
                            borderWidth: 3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: 'rgba(10, 10, 15, 0.9)',
                                titleFont: { size: 14, family: 'Outfit' },
                                bodyFont: { size: 13, family: 'Inter' },
                                padding: 12,
                                borderColor: 'rgba(0, 229, 255, 0.3)',
                                borderWidth: 1,
                                callbacks: { label: (ctx) => `  Consistency Score: ${ctx.raw}%` }
                            },
                            zoom: {
                                pan: { enabled: true, mode: 'x' },
                                zoom: {
                                    wheel: { enabled: true },
                                    pinch: { enabled: true },
                                    mode: 'x'
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: { color: 'rgba(255,255,255,0.03)' },
                                ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 10 } }
                            },
                            y: {
                                min: 0, max: 100,
                                grid: { color: 'rgba(255,255,255,0.03)' },
                                ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 10 } }
                            }
                        }
                    }
                });
                // Reset zoom on double click
                ctxCon.ondblclick = () => charts.consistency.resetZoom();
            }

            // B) Win Rate (Doughnut)
            const winRate = possibleChecks > 0 ? Math.round((totalChecks / possibleChecks) * 100) : 0;
            const txtWin = document.getElementById('txtWinRate');
            if (txtWin) txtWin.innerText = winRate + "%";

            const ctxWin = document.getElementById('chartWinRate');
            if (ctxWin) {
                if (charts.winRate) charts.winRate.destroy();
                charts.winRate = new Chart(ctxWin, {
                    type: 'doughnut',
                    data: {
                        labels: ['Done', 'Missed'],
                        datasets: [{
                            data: [winRate, 100 - winRate],
                            backgroundColor: ['#ffd700', 'rgba(255,255,255,0.03)'], // Gold
                            borderWidth: 0,
                            hoverOffset: 12
                        }]
                    },
                    options: {
                        cutout: '80%',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        animation: { animateScale: true, duration: 1500 }
                    }
                });
            }

            // C) Top Habits
            const scores = {};
            trackerData.template.forEach(h => scores[h] = 0);
            for (let d = 1; d <= daysInMonth; d++) {
                const dStr = getDatestamp(new Date(year, month, d));
                const log = trackerData.logs[dStr];
                if (log) log.tasks.forEach(t => { if (t.status === 'executed' && scores[t.name] !== undefined) scores[t.name]++; });
            }
            const sorted = Object.entries(scores).sort((a, b) => b[1] - a[1]).slice(0, 6);
            const listEl = document.getElementById('topHabitsList');
            if (listEl) {
                listEl.innerHTML = '';
                sorted.forEach(([name, count]) => {
                    const row = document.createElement('div');
                    row.style.cssText = 'display:flex; justify-content:space-between; align-items:center; font-size:0.85rem; padding:0.8rem 1rem; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.05); border-radius:12px; transition:0.3s;';
                    row.innerHTML = `<span style="color:#eee;">${name}</span> <span style="font-weight:700; color:var(--primary); background:rgba(255,215,0,0.1); padding:2px 10px; border-radius:20px; font-size:0.75rem;">${count} WINS</span>`;
                    listEl.appendChild(row);
                });
            }

            // D) Real-Time Performance Metrics
            const todayStr = getDatestamp(new Date());
            const todayLog = trackerData.logs[todayStr];
            const currentFocus = todayLog ? todayLog.score : 0;

            // Stress is inverse of focus + some random "noise" for real-time vibe
            const currentStress = Math.max(0, Math.min(100, (100 - currentFocus) + (Math.random() * 10 - 5)));

            // Recovery: Avg of last 5 days
            let totalLast5 = 0;
            let countLast5 = 0;
            for (let i = 0; i < 5; i++) {
                let dIdx = new Date(); dIdx.setDate(dIdx.getDate() - i);
                let dStr = getDatestamp(dIdx);
                if (trackerData.logs[dStr]) { totalLast5 += trackerData.logs[dStr].score; countLast5++; }
            }
            const currentRecovery = countLast5 > 0 ? Math.round(totalLast5 / countLast5) : 0;

            // UI Update
            const stressBar = document.getElementById('metricStressBar');
            const focusBar = document.getElementById('metricFocusBar');
            const recoveryBar = document.getElementById('metricRecoveryBar');

            if (stressBar) { stressBar.style.height = currentStress + "%"; document.getElementById('metricStressVal').innerText = Math.round(currentStress) + "%"; }
            if (focusBar) { focusBar.style.height = currentFocus + "%"; document.getElementById('metricFocusVal').innerText = currentFocus + "%"; }
            if (recoveryBar) { recoveryBar.style.height = currentRecovery + "%"; document.getElementById('metricRecoveryVal').innerText = currentRecovery + "%"; }
        }



        // 3. RENDER ANALOG (Protocols & Mood)
        function renderAnalog() {
            const todayStr = getDatestamp(new Date());
            const protocolData = trackerData.protocols[todayStr] || {};

            const listEl = document.getElementById('protocolList');
            if (listEl) {
                listEl.innerHTML = '';
                const protocols = ["No Snooze", "Read 10 Pages", "Clear Inbox", "Plan Tomorrow"];

                protocols.forEach(p => {
                    const isChecked = !!protocolData[p];
                    const label = document.createElement('label');
                    label.style.cssText = 'display: flex; gap: 0.5rem; align-items: center; cursor: pointer; padding: 0.2rem;';
                    label.innerHTML = `
                        <input type="checkbox" ${isChecked ? 'checked' : ''} onchange="toggleProtocol('${p}')">
                        <span style="font-size: 0.9rem; color: ${isChecked ? 'var(--text-main)' : 'var(--text-secondary)'}; text-decoration: ${isChecked ? 'line-through' : 'none'}">${p}</span>
                    `;
                    listEl.appendChild(label);
                });
            }


        }

        async function toggleProtocol(name) {
            const todayStr = getDatestamp(new Date());
            if (!trackerData.protocols[todayStr]) trackerData.protocols[todayStr] = {};

            const current = !!trackerData.protocols[todayStr][name];
            trackerData.protocols[todayStr][name] = !current;

            renderAnalog();
            await fetch('/api/tracker/protocol', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ date: todayStr, protocols: trackerData.protocols[todayStr] })
            });
        }


        // Initialize on Load
        initTracker();

        // 5. LIVE HUD JITTER (Visual Polish)
        setInterval(() => {
            const stressBar = document.getElementById('metricStressBar');
            const stressVal = document.getElementById('metricStressVal');
            if (stressBar && stressVal) {
                const current = parseInt(stressVal.innerText);
                const jitter = (Math.random() * 4 - 2); // +/- 2%
                const newVal = Math.max(0, Math.min(100, current + jitter));
                stressBar.style.height = newVal + "%";
                stressVal.innerText = Math.round(newVal) + "%";
            }
        }, 3000); // Pulse every 3s

        // AUTOMATION BOT
        function botCmd(action) {
            const consoleDiv = document.getElementById('botConsole');
            const timestamp = new Date().toLocaleTimeString();
            let msg = '';

            if (action === 'clear') {
                consoleDiv.innerHTML = '<div style="margin-bottom: 0.5rem;">[SYSTEM] Console Cleared.</div>';
                return;
            }

            if (action === 'scan_jobs') msg = `[${timestamp}] Scanning LinkedIn/Indeed for "Business Analyst"... Found 12 matches.`;
            if (action === 'optimize_resume') msg = `[${timestamp}] Analyzing keywords... ATS Score: 92/100.`;
            if (action === 'auto_apply') msg = `[${timestamp}] Simulating application to Google... Success.`;

            const div = document.createElement('div');
            div.style.marginBottom = '0.5rem';
            div.style.color = '#fff';
            div.innerHTML = `<span style="color:var(--primary);">></span> ${msg}`;
            consoleDiv.appendChild(div);
            consoleDiv.scrollTop = consoleDiv.scrollHeight;
        }

        // ATTENDANCE CLOCK
        function updateClock() {
            const now = new Date();
            const timeString = now.toLocaleTimeString('en-US', { hour12: false });
            const dateString = now.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

            const clockEl = document.getElementById('digitalClock');
            const dateEl = document.getElementById('currentDate');

            if (clockEl) clockEl.innerText = timeString;
            if (dateEl) dateEl.innerText = dateString;
        }
        setInterval(updateClock, 1000);
        updateClock(); // init

        function logAttendance(type) {
            const log = document.getElementById('attendanceLog');
            const li = document.createElement('li');
            li.style.cssText = 'padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); color: #fff; display:flex; justify-content:space-between;';
            li.innerHTML = `<span>${type}</span> <span style="color:var(--text-secondary);">${new Date().toLocaleTimeString()}</span>`;

            // Remove "No activity" text if present
            if (log.children[0] && log.children[0].innerText.includes('No activity')) log.innerHTML = '';

            log.prepend(li);
        }

        renderTasks();

        // CALENDAR MODAL
        function showAddEventModal() {
            document.getElementById('eventModal').style.display = 'flex';
        }

    </script>
</body>

</html>