<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Srijan | Command Center</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap"
        rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1"></script>
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js'></script>

    <style>
        :root {
            /* Palette - "Cyber-Executive" */
            --bg-body: #050507;
            --bg-sidebar: #0b0b0f;
            --bg-card: #121218;
            --bg-card-hover: #1a1a22;

            --border-subtle: rgba(255, 255, 255, 0.06);
            --border-focus: rgba(255, 255, 255, 0.15);

            --primary: #536dfe;
            /* Indigo */
            --primary-glow: rgba(83, 109, 254, 0.3);
            --accent: #00e5ff;
            /* Cyan */
            --text-main: #ffffff;
            --text-secondary: #9494a0;

            --success: #00c853;
            --danger: #ff1744;

            --glass: rgba(255, 255, 255, 0.02);
            --nav-item-h: 48px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            outline: none;
        }

        /* START: SCROLLBAR MANAGEMENT */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        html {
            scrollbar-width: none;
            -ms-overflow-style: none;
        }

        html::-webkit-scrollbar,
        body::-webkit-scrollbar {
            display: none;
            width: 0;
            height: 0;
        }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow-x: hidden;
            display: flex;
            min-height: 100vh;
        }

        /* --- SIDEBAR DESIGN --- */
        .sidebar {
            width: 260px;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-subtle);
            height: 100vh;
            position: sticky;
            top: 0;
            display: flex;
            flex-direction: column;
            padding: 2rem 1.5rem;
            flex-shrink: 0;
            z-index: 50;
        }

        .brand-container {
            margin-bottom: 3.5rem;
            padding-left: 0.5rem;
        }

        .brand {
            font-family: 'Outfit', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: white;
            letter-spacing: -0.01em;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .brand-dot {
            width: 8px;
            height: 8px;
            background: var(--accent);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--accent);
        }

        .nav-menu {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .nav-item {
            position: relative;
            height: var(--nav-item-h);
            display: flex;
            align-items: center;
            padding: 0 1.25rem;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 500;
            border-radius: 12px;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            cursor: pointer;
            overflow: hidden;
        }

        .nav-item i {
            width: 24px;
            margin-right: 12px;
            font-size: 1.1rem;
            transition: color 0.3s ease;
        }

        /* Hover Effect */
        .nav-item:hover {
            color: white;
            background: rgba(255, 255, 255, 0.03);
        }

        /* Active Effect */
        .nav-item.active {
            color: white;
            background: linear-gradient(90deg, rgba(83, 109, 254, 0.1), transparent);
        }

        .nav-item.active i {
            color: var(--primary);
            text-shadow: 0 0 15px var(--primary-glow);
        }

        .nav-item.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 15%;
            bottom: 15%;
            width: 4px;
            background: var(--primary);
            border-radius: 0 4px 4px 0;
            box-shadow: 2px 0 10px var(--primary-glow);
        }

        /* --- MAIN AREA --- */
        .main-content {
            flex: 1;
            padding: 2.5rem 3.5rem;
            width: calc(100% - 260px);
            /* fallback */
            width: 0;
            /* allows grid to shrink properly if needed */
            min-width: 0;
            /* Flexbox trick for text overflow */
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 3rem;
            border-bottom: 1px solid var(--border-subtle);
            padding-bottom: 1.5rem;
        }

        .page-header h1 {
            font-family: 'Outfit', sans-serif;
            font-size: 2.2rem;
            font-weight: 500;
            margin-bottom: 0.25rem;
        }

        .page-header p {
            color: var(--text-secondary);
            font-size: 0.95rem;
        }

        .user-status {
            display: flex;
            gap: 1rem;
            align-items: center;
            background: var(--bg-card);
            padding: 0.5rem 0.75rem 0.5rem 1.25rem;
            border-radius: 50px;
            border: 1px solid var(--border-subtle);
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #333;
            overflow: hidden;
            border: 2px solid var(--bg-body);
        }

        /* --- LAYOUTS --- */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        @media(max-width: 1200px) {
            .dashboard-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media(max-width: 800px) {
            body {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                padding: 1rem;
                border-right: none;
                border-bottom: 1px solid var(--border-subtle);
            }

            .main-content {
                width: 100%;
                padding: 1.5rem;
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
            }

            .nav-menu {
                flex-direction: row;
                overflow-x: auto;
                padding-bottom: 0.5rem;
                gap: 0.5rem;
            }

            .nav-item {
                padding: 0.5rem 1rem;
                height: auto;
                border-radius: 8px;
                font-size: 0.8rem;
                white-space: nowrap;
            }

            .nav-item i {
                margin-right: 6px;
                font-size: 1rem;
            }

            .nav-item.active::before {
                bottom: 0;
                top: auto;
                width: 100%;
                height: 3px;
                left: 0;
                border-radius: 3px 3px 0 0;
            }

            .brand-container {
                margin-bottom: 1rem;
                display: flex;
                justify-content: center;
            }

            .brand {
                font-size: 1.2rem;
            }

            /* Hide chart on very small screens if needed, or adjust height */
            canvas {
                max-height: 200px;
            }
        }

        /* --- CARDS --- */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 16px;
            padding: 1.75rem;
            position: relative;
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease, border-color 0.3s ease;
        }

        .card:hover {
            transform: translateY(-4px);
            border-color: var(--border-focus);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
            background: var(--bg-card-hover);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .card-title {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-secondary);
            font-weight: 600;
        }

        .stat-big {
            font-family: 'Outfit', sans-serif;
            font-size: 3rem;
            font-weight: 600;
            color: white;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        /* --- FORMS & INPUTS --- */
        .input-group {
            margin-bottom: 1.5rem;
        }

        .input-label {
            display: block;
            margin-bottom: 0.7rem;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        input[type="text"],
        input[type="password"],
        textarea {
            width: 100%;
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid var(--border-subtle);
            color: white;
            padding: 1rem 1.25rem;
            border-radius: 10px;
            font-family: inherit;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        input:focus,
        textarea:focus {
            border-color: var(--primary);
            background: rgba(83, 109, 254, 0.05);
            box-shadow: 0 0 0 3px rgba(83, 109, 254, 0.1);
        }

        /* --- BUTTONS --- */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.75rem 1.75rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            border: none;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
            box-shadow: 0 4px 15px rgba(83, 109, 254, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(83, 109, 254, 0.4);
            filter: brightness(1.1);
        }

        .btn-danger {
            background: rgba(255, 23, 68, 0.1);
            color: var(--danger);
            border: 1px solid rgba(255, 23, 68, 0.2);
        }

        .btn-danger:hover {
            background: var(--danger);
            color: white;
        }

        .btn-ghost {
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--border-subtle);
        }

        .btn-ghost:hover {
            border-color: white;
            color: white;
        }

        /* --- INBOX LIST --- */
        .mail-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .mail-item {
            display: grid;
            grid-template-columns: 50px 1fr auto;
            gap: 1rem;
            padding: 1.25rem;
            background: var(--glass);
            border-radius: 12px;
            border: 1px solid transparent;
            transition: all 0.2s;
            align-items: center;
        }

        .mail-item:hover {
            background: var(--bg-card-hover);
            border-color: var(--border-subtle);
        }

        .mail-item.unread {
            border-left: 3px solid var(--accent);
            background: rgba(0, 229, 255, 0.03);
        }

        .avatar-initial {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, #1f1f2e, #141419);
            color: var(--primary);
            font-family: 'Outfit';
            font-weight: 700;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--border-subtle);
        }

        /* --- PROJECTS GRID --- */
        .project-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        .project-card {
            background: var(--bg-card);
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--border-subtle);
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
        }

        .project-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary);
        }

        .p-body {
            padding: 1.5rem;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .p-title {
            font-family: 'Outfit';
            font-size: 1.2rem;
            margin-bottom: 0.5rem;
        }

        .p-desc {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.5;
            margin-bottom: 1.5rem;
            flex: 1;
        }

        .tag-pill {
            font-size: 0.75rem;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.05);
            color: #ccc;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* --- UTILITY --- */
        .tab-section {
            display: none;
            animation: contentFade 0.4s ease forwards;
        }

        .tab-section.active {
            display: block;
        }

        @keyframes contentFade {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* --- FullCalendar Theme Overrides --- */
        .fc {
            font-family: 'Plus Jakarta Sans', sans-serif !important;
        }

        .fc-theme-standard .fc-scrollgrid,
        .fc-theme-standard td,
        .fc-theme-standard th {
            border-color: var(--border-subtle) !important;
        }

        .fc-col-header-cell {
            background: rgba(255, 255, 255, 0.02);
            padding: 10px 0;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
        }

        .fc-day-today {
            background: rgba(83, 109, 254, 0.05) !important;
            /* Primary faint */
        }

        .fc-button-primary {
            background-color: var(--bg-card) !important;
            border-color: var(--border-subtle) !important;
            color: var(--text-secondary) !important;
            text-transform: capitalize;
            font-weight: 500;
        }

        .fc-button-primary:hover,
        .fc-button-primary.fc-button-active {
            background-color: var(--primary) !important;
            border-color: var(--primary) !important;
            color: #fff !important;
        }

        .fc-event {
            border: none !important;
            border-radius: 4px;
            padding: 2px 4px;
            font-size: 0.85rem;
        }

        .fc-event-main {
            color: white;
        }

        .fc-daygrid-event {
            background-color: rgba(83, 109, 254, 0.2);
            border-left: 3px solid var(--primary) !important;
        }

        .fc-timegrid-event {
            background-color: var(--primary);
        }

        .fc-timegrid-slot-label-cushion,
        .fc-timegrid-axis-cushion {
            color: var(--text-secondary);
            font-size: 0.8rem;
        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <nav class="sidebar">
        <div class="brand-container">
            <div class="brand">
                SRI<div class="brand-dot"></div>
            </div>
        </div>

        <div class="nav-menu">
            <a onclick="switchTab('overview', this)" class="nav-item active">
                <i class="fas fa-grid-2"></i> <span>Overview</span>
            </a>
            <a onclick="switchTab('inbox', this)" class="nav-item">
                <i class="fas fa-inbox"></i> <span>Inbox</span>
                <% if(typeof messages !=='undefined' && messages.some(m=> !m.read)) { %>
                    <span
                        style="margin-left:auto; width:6px; height:6px; background:var(--danger); border-radius:50%;"></span>
                    <% } %>
            </a>
            <a onclick="switchTab('projects', this)" class="nav-item">
                <i class="fas fa-folder-open"></i> <span>Projects</span>
            </a>

            <!-- NEW MODULES -->
            <a onclick="switchTab('attendance', this)" class="nav-item">
                <i class="fas fa-clock"></i> <span>Attendance</span>
            </a>
            <a onclick="switchTab('progress', this)" class="nav-item">
                <i class="fas fa-tasks"></i> <span>Tracker</span>
            </a>
            <a onclick="switchTab('automation', this)" class="nav-item">
                <i class="fas fa-robot"></i> <span>Auto-Bot</span>
            </a>
            <a onclick="switchTab('calendar', this)" class="nav-item">
                <i class="fas fa-calendar-alt"></i> <span>Calendar</span>
            </a>

            <a onclick="switchTab('bio', this)" class="nav-item">
                <i class="fas fa-pen-nib"></i> <span>Edit Content</span>
            </a>
            <a onclick="switchTab('settings', this)" class="nav-item">
                <i class="fas fa-cog"></i> <span>Settings</span>
            </a>
        </div>

        <div style="margin-top: auto;">
            <a href="/logout" class="nav-item" style="color: var(--danger);">
                <i class="fas fa-sign-out-alt"></i> <span>Log Out</span>
            </a>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="main-content">

        <!-- HEADER -->
        <header class="top-bar">
            <div class="page-header">
                <h1 id="pageTitle">Overview</h1>
                <p>Welcome back, Admin</p>
            </div>

            <div class="user-status">
                <div style="text-align: right; line-height: 1.2;">
                    <div style="font-weight: 600; font-size: 0.9rem;">Administrator</div>
                    <div style="font-size: 0.75rem; color: var(--success);">● LIVE</div>
                </div>
                <div class="user-avatar">
                    <img src="/assets/profile.jpg" alt="A" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
            </div>
        </header>

        <!-- 1. OVERVIEW -->
        <section id="overview" class="tab-section active">
            <div class="dashboard-grid">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Project Portfolio</span>
                        <i class="fas fa-briefcase" style="color: var(--primary);"></i>
                    </div>
                    <div class="stat-big">
                        <%= (typeof content.resume.projects !=='undefined' ) ? content.resume.projects.length : 0 %>
                    </div>
                    <div style="font-size: 0.9rem; color: var(--text-secondary);">Active case studies</div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <span class="card-title">Total Inquiries</span>
                        <i class="fas fa-envelope" style="color: var(--accent);"></i>
                    </div>
                    <div class="stat-big">
                        <%= (typeof messages !=='undefined' ) ? messages.length : 0 %>
                    </div>
                    <div style="font-size: 0.9rem; color: var(--text-secondary);">Messages received</div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <span class="card-title">System Health</span>
                        <i class="fas fa-server" style="color: var(--success);"></i>
                    </div>
                    <div class="stat-big" style="color: var(--success); font-size: 1.8rem;">100%</div>
                    <div style="font-size: 0.9rem; color: var(--text-secondary);">Uptime & Persistence</div>
                </div>
            </div>

            <!-- Chart Only (Traffic) -->
            <div class="card">
                <div class="card-header">
                    <span class="card-title">Traffic Analytics</span>
                </div>
                <div style="height: 300px; width: 100%;">
                    <canvas id="mainChart"></canvas>
                </div>
            </div>
        </section>

        <!-- 2. INBOX -->
        <section id="inbox" class="tab-section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                <h2>Messages</h2>
                <span style="font-size: 0.9rem; color: var(--text-secondary);">
                    <%= (typeof messages !=='undefined' ) ? messages.filter(m=>!m.read).length : 0 %> Unread
                </span>
            </div>

            <div class="mail-list">
                <% if(typeof messages !=='undefined' && messages.length> 0) { %>
                    <% messages.forEach(msg=> { %>
                        <div class="mail-item <%= msg.read ? '' : 'unread' %>">
                            <div class="avatar-initial">
                                <%= msg.name.charAt(0) %>
                            </div>
                            <div>
                                <div style="display: flex; align-items: baseline; gap: 1rem; margin-bottom: 0.25rem;">
                                    <h3 style="font-size: 1.1rem; color: white;">
                                        <%= msg.name %>
                                    </h3>
                                    <span style="font-size: 0.85rem; color: var(--text-secondary);">
                                        <%= msg.date %>
                                    </span>
                                </div>
                                <div style="font-size: 0.9rem; color: var(--text-secondary);">
                                    <%= msg.email %>
                                </div>
                                <p style="margin-top: 0.5rem; color: #ddd; line-height: 1.4;">
                                    <%= msg.message %>
                                </p>
                            </div>
                            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                                <% if(!msg.read) { %>
                                    <form action="/admin/messages/read" method="POST">
                                        <input type="hidden" name="id" value="<%= msg.id %>">
                                        <button class="btn btn-ghost" style="width: 100%; font-size: 0.8rem;">Mark
                                            Read</button>
                                    </form>
                                    <% } %>
                                        <form action="/admin/messages/delete" method="POST"
                                            onsubmit="return confirm('Archive this message?');">
                                            <input type="hidden" name="id" value="<%= msg.id %>">
                                            <button class="btn btn-danger" style="width: 100%; padding: 0.5rem;"><i
                                                    class="fas fa-trash"></i></button>
                                        </form>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div style="text-align: center; padding: 4rem; color: var(--text-secondary);">
                                    <i class="fas fa-inbox"
                                        style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;"></i>
                                    <p>Inbox is empty</p>
                                </div>
                                <% } %>
            </div>
        </section>

        <!-- 3. PROJECTS -->
        <section id="projects" class="tab-section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                <h2>Projects</h2>
                <button class="btn btn-primary" onclick="openProjectModal()">+ New Project</button>
            </div>

            <div class="project-grid">
                <% if(typeof content.resume.projects !=='undefined' ) { %>
                    <% content.resume.projects.forEach(proj=> { %>
                        <div class="project-card">
                            <div class="p-body">
                                <h3 class="p-title">
                                    <%= proj.title %>
                                </h3>
                                <p class="p-desc">
                                    <%= proj.desc %>
                                </p>
                                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                    <% proj.tags.forEach(t=> { %>
                                        <span class="tag-pill">
                                            <%= t %>
                                        </span>
                                        <% }) %>
                                </div>
                            </div>
                            <div
                                style="padding: 1rem; background: rgba(0,0,0,0.2); border-top: 1px solid var(--border-subtle); display: flex; justify-content: flex-end; gap: 0.5rem;">
