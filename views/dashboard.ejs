                    style="border-bottom: 1px solid var(--border-subtle); padding-bottom: 1rem; margin-bottom: 2rem;">
                    <h3 class="card-title" style="font-size: 1.2rem; color: white;">Global Content Manager</h3>
                </div>

                <!-- 1. HERO & INTRO -->
                <form action="/admin/update-content" method="POST" style="margin-bottom: 3rem;">
                    <h4 style="color: var(--primary); margin-bottom: 1rem;">Hompeage Hero Section</h4>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                        <div class="input-group">
                            <label class="input-label">Hero Title (HTML Allowed)</label>
                            <input type="text" name="hero[title]" value="<%= content.hero ? content.hero.title : '' %>">
                        </div>
                        <div class="input-group">
                            <label class="input-label">Hero Subtitle</label>
                            <input type="text" name="hero[subtitle]"
                                value="<%= content.hero ? content.hero.subtitle : '' %>">
                        </div>
                    </div>
                    <div class="input-group">
                        <label class="input-label">Hero Description</label>
                        <textarea name="hero[desc]" rows="2"><%= content.hero ? content.hero.desc : '' %></textarea>
                    </div>

                    <h4 style="color: var(--accent); margin-bottom: 1rem; margin-top: 2rem;">About Section</h4>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                        <div class="input-group">
                            <label class="input-label">About Name/Title</label>
                            <input type="text" name="about[title]"
                                value="<%= content.about ? content.about.title : '' %>">
                        </div>
                        <div class="input-group">
                            <label class="input-label">About Subtitle</label>
                            <input type="text" name="about[subtitle]"
                                value="<%= content.about ? content.about.subtitle : '' %>">
                        </div>
                    </div>
                    <div class="input-group">
                        <label class="input-label">Personal Bio (HTML Allowed)</label>
                        <textarea name="about[bio]" rows="6"
                            style="line-height: 1.6;"><%= content.about ? content.about.bio : content.bio %></textarea>
                    </div>

                    <div style="text-align: right;">
                        <button class="btn btn-primary">Save Text Content</button>
                    </div>
                </form>

                <!-- 2. RESUME UPLOAD -->
                <div
                    style="background: rgba(255,255,255,0.02); padding: 1.5rem; border-radius: 12px; margin-bottom: 3rem; border: 1px solid var(--border-subtle);">
                    <h4 style="margin-bottom: 1rem; color: white;">Update PDF Resume</h4>
                    <form action="/admin/resume" method="POST" enctype="multipart/form-data"
                        style="display: flex; gap: 1rem; align-items: center;">
                        <input type="file" name="resume" accept=".pdf" required
                            style="flex: 1; background: transparent; border: none; padding: 0;">
                        <button class="btn btn-ghost" style="padding: 0.5rem 1rem; font-size: 0.85rem;">Upload New
                            PDF</button>
                    </form>
                </div>

                <!-- 3. CERTIFICATIONS -->
                <div style="border-top: 1px solid var(--border-subtle); padding-top: 2rem;">
                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                        <h4 style="color: white; margin: 0;">Certifications & Awards</h4>
                        <button class="btn btn-primary"
                            onclick="document.getElementById('addCertModal').style.display='flex'">+ Add New</button>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                        <% if(content.certifications && content.certifications.length> 0) { %>
                            <% content.certifications.forEach(cert=> { %>
                                <div
                                    style="display: flex; justify-content: space-between; align-items: center; background: var(--glass); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-subtle);">
                                    <div style="display: flex; gap: 1rem; align-items: center;">
                                        <div
                                            style="width: 40px; height: 40px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; border-radius: 8px;">
                                            <i class="<%= cert.icon %>"></i>
                                        </div>
                                        <div>
                                            <div style="font-weight: 600;">
                                                <%= cert.name %>
                                            </div>
                                            <div style="font-size: 0.8rem; color: var(--text-secondary);">
                                                <%= cert.issuer %>
                                            </div>
                                        </div>
                                    </div>
                                    <form action="/admin/certifications/delete" method="POST"
                                        onsubmit="return confirm('Delete this certification?');">
                                        <input type="hidden" name="id" value="<%= cert.id %>">
                                        <button class="btn btn-danger" style="padding: 0.4rem;"><i
                                                class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div style="text-align: center; color: var(--text-secondary); padding: 1rem;">No
                                            certifications added yet.</div>
                                        <% } %>
                    </div>
                </div>
            </div>

            <!-- ADD CERT MODAL -->
            <div id="addCertModal"
                style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.8); z-index: 1000; align-items:center; justify-content:center;">
                <div class="card" style="width: 400px; max-width: 90%;">
                    <h3 style="margin-bottom: 1.5rem;">Add Certification</h3>
                    <form action="/admin/certifications/add" method="POST">
                        <div class="input-group">
                            <label class="input-label">Certification Name</label>
                            <input type="text" name="name" required>
                        </div>
                        <div class="input-group">
                            <label class="input-label">Issuer</label>
                            <input type="text" name="issuer" required>
                        </div>
                        <div class="input-group">
                            <label class="input-label">Icon Class (FontAwesome)</label>
                            <input type="text" name="icon" placeholder="fa-solid fa-certificate"
                                value="fa-solid fa-certificate">
                        </div>
                        <div class="input-group">
                            <label class="input-label">Custom Style (CSS)</label>
                            <input type="text" name="style" placeholder="border-color: gold; ...">
                        </div>
                        <div style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 1rem;">
                            <button type="button" class="btn btn-ghost"
                                onclick="document.getElementById('addCertModal').style.display='none'">Cancel</button>
                            <button class="btn btn-primary">Add Cert</button>
                        </div>
                    </form>
                </div>
            </div>
        </section>

        <!-- 6. ACADEMIC ATTENDANCE (GCAL SYNC) -->
        <section id="attendance" class="tab-section">
            <div class="card" style="margin-bottom: 2rem;">
                <div class="card-header">
                    <span class="card-title">Attendance Tracker</span>
                    <button class="btn btn-primary"
                        onclick="document.getElementById('addSubjectModal').style.display='flex'">
                        + Add Subject
                    </button>
                </div>
                <!-- Container for Async Loaded Content -->
                <div id="attendanceContent"
                    style="min-height: 200px; display: flex; flex-direction: column; gap: 1rem;">
                    <div style="text-align: center; color: var(--text-secondary); padding: 2rem;">
                        <i class="fas fa-sync fa-spin"></i> Syncing with Google Calendar...
                    </div>
                </div>
            </div>

            <!-- UNMARKED CLASSES -->
            <div id="unmarkedSection" class="card" style="display: none;">
                <div class="card-header"
                    style="border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 1rem; margin-bottom: 1rem;">
                    <span class="card-title" style="color: var(--warning);">⚠️ Unmarked Classes</span>
                </div>
                <div id="unmarkedList"></div>
            </div>

            <!-- ADD SUBJECT MODAL -->
            <div id="addSubjectModal"
                style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.8); z-index: 1000; align-items:center; justify-content:center;">
                <div class="card" style="width: 400px; max-width: 90%;">
                    <h3 style="margin-bottom: 1.5rem;">Track New Course</h3>
                    <form action="/api/attendance/add" method="POST">
                        <div class="input-group">
                            <label class="input-label">Course Name</label>
