                        <div style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 1rem;">
                            <button type="button" class="btn btn-ghost"
                                onclick="document.getElementById('addSubjectModal').style.display='none'">Cancel</button>
                            <button class="btn btn-primary">Start Tracking</button>
                        </div>
                    </form>
                </div>
            </div>
        </section>

        <!-- 7. TRACKER V4: HYBRID SYSTEM -->
        <section id="progress" class="tab-section">
            <style>
                .tracker-layout {
                    display: grid;
                    grid-template-columns: 3fr 1fr;
