                        <div style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 1rem;">
                            <button type="button" class="btn btn-ghost"
                                onclick="document.getElementById('projectModal').style.display='none'">Cancel</button>
                            <button class="btn btn-primary" id="projectSubmitBtn">Publish Project</button>
                        </div>
                    </form>
                </div>
            </div>

        </section>

        <!-- 4. BIO -->
        <!-- 4. CONTENT MANAGEMENT (CMS) -->
        <section id="bio" class="tab-section">
            <div class="card" style="max-width: 900px; margin: 0 auto;">
